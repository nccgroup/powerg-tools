- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass blk(gr.sync_block):  # other base classes\
      \ are basic_block, decim_block, interp_block\n    \"\"\"CFO Estimator (RMS)\"\
      \"\"\n\n    def __init__(self, vector_size=2048, sample_rate=10000, center_freq=0):\
      \  # only default arguments here\n        \"\"\"arguments to this function show\
      \ up as parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n         \
      \   self,\n            name='CFO Estimator (RMS)',   # will show up in GRC\n\
      \            in_sig=[(np.float32, vector_size)],\n            out_sig=[np.float32]\n\
      \        )\n        # if an attribute with the same name as a parameter is found,\n\
      \        # a callback is registered (properties work, too).\n        self.vector_size\
      \ = vector_size\n        self.sample_rate = sample_rate\n        self.center_freq\
      \ = center_freq\n        \n        self._start_freq = self.center_freq - (self.sample_rate\
      \ / 2)\n        self.freq_axis = [self._start_freq + (self.sample_rate/self.vector_size)\
      \ * x for x in range(self.vector_size)]\n\n    def work(self, input_items, output_items):\n\
      \        \"\"\"Estimate offset with RMS on FFT outputs\"\"\"\n\n        for\
      \ vec_i, vector in enumerate(input_items[0]):\n            energy = 0\n    \
      \        top_integral = 0\n\n            # mag^2 output per FFT bin\n      \
      \      for i, mag in enumerate(vector):\n                energy += mag\n   \
      \             top_integral += mag * self.freq_axis[i]\n            \n      \
      \      if energy == 0:\n                cf_estimate = 0\n            else:\n\
      \                cf_estimate = top_integral / energy\n            \n       \
      \     output_items[0][vec_i] = cf_estimate\n                \n        return\
      \ len(output_items[0])\n\n"
    affinity: ''
    alias: ''
    center_freq: '0'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: decimated_samp_rate
    vector_size: fft_vec_sz
  states:
    _io_cache: ('CFO Estimator (RMS)', 'blk', [('vector_size', '2048'), ('sample_rate',
      '10000'), ('center_freq', '0')], [('0', 'float', 2048)], [('0', 'float', 1)],
      'CFO Estimator (RMS)', ['center_freq', 'sample_rate', 'vector_size'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1448, 972.0]
    rotation: 0
    state: true
- name: epy_block_0_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass blk(gr.sync_block):  # other base classes\
      \ are basic_block, decim_block, interp_block\n    \"\"\"CFO Correction (Hz)\"\
      \"\"\n\n    def __init__(self, sample_rate=32000, max_shift=19000):  # only\
      \ default arguments here\n        \"\"\"arguments to this function show up as\
      \ parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n            self,\n\
      \            name='CFO Correct',   # will show up in GRC\n            in_sig=[np.complex64,\
      \ np.float32],\n            out_sig=[np.complex64]\n        )\n        # if\
      \ an attribute with the same name as a parameter is found,\n        # a callback\
      \ is registered (properties work, too).\n        self.sample_rate = sample_rate\n\
      \        self.max_shift = max_shift\n        \n    def rads_to_hz(self, rads):\n\
      \    \treturn (rads / (2*np.pi)) * self.sample_rate\n\n    def work(self, input_items,\
      \ output_items):\n        \"\"\"CFO correct samples using frequency offset estimation\"\
      \"\"\n\n        for n, offset in enumerate(input_items[1]):\n        \tif offset\
      \ < (-self.max_shift):\n        \t    offset = -self.max_shift\n        \telif\
      \ offset > self.max_shift:\n        \t    offset = self.max_shift\n        \t\
      \n        \tshift_amt = np.e ** (1j * np.pi * (-offset / (self.sample_rate/2))\
      \ * n)\n        \t\n        \toutput_items[0][n] = input_items[0][n] * shift_amt\n\
      \        \n        return len(output_items[0])\n        \n"
    affinity: ''
    alias: ''
    comment: ''
    max_shift: deviation_for_freq
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: decimated_samp_rate
  states:
    _io_cache: ('CFO Correct', 'blk', [('sample_rate', '32000'), ('max_shift', '19000')],
      [('0', 'complex', 1), ('1', 'float', 1)], [('0', 'complex', 1)], 'CFO Correction
      (Hz)', ['max_shift', 'sample_rate'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1944, 936.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass blk(gr.sync_block):  # other base classes\
      \ are basic_block, decim_block, interp_block\n    \"\"\"Embedded Python Block\
      \ example - a simple multiply const\"\"\"\n\n    def __init__(self, sync_word=0x1F351F35,\
      \ sync_bits=32):  # only default arguments here\n        \"\"\"arguments to\
      \ this function show up as parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n\
      \            self,\n            name='Sync Word Finder',   # will show up in\
      \ GRC\n            in_sig=[np.ubyte],\n            out_sig=[np.short]\n    \
      \    )\n        \n        if sync_word == 0:\n            raise Exception('sync\
      \ word of 0 not supported')\n        \n        # if an attribute with the same\
      \ name as a parameter is found,\n        # a callback is registered (properties\
      \ work, too).\n        self.sync_word = sync_word\n        self.sync_bits =\
      \ sync_bits\n        \n        # register for shifting in sync word\n      \
      \  self.sync_mask = 2**self.sync_bits - 1\n        self.shift_reg = 0\n    \
      \    \n        # shift in data bytes\n        self.shift_byte = 0\n        self.shift_byte_bits\
      \ = 0\n        \n        self.pkt_len = 0\n        \n        self.sync_state\
      \ = 0\n\n    def work(self, input_items, output_items):\n    \n        # output\
      \ byte array\n        #output_items[1] = []\n\n        for i, bit in enumerate(input_items[0]):\n\
      \            \n            # find sync word\n            if self.sync_state\
      \ == 0:\n                self.shift_reg = ((self.shift_reg << 1) | (bit & 1))\
      \ & self.sync_mask\n                \n                if self.shift_reg == self.sync_word:\n\
      \                    output_items[0][i] = 1\n                    \n        \
      \            # transition to state 1\n                    self.sync_state =\
      \ 1\n                    self.shift_byte = 0\n                    self.shift_byte_bits\
      \ = 0\n                    continue\n                else:\n               \
      \     output_items[0][i] = 0\n                    \n            # shift in length\
      \ byte\n            if self.sync_state == 1:\n                self.shift_byte\
      \ = ((self.shift_byte << 1) | (bit & 1)) & 0xFF\n                self.shift_byte_bits\
      \ += 1\n                \n                output_items[0][i] = 1\n         \
      \       \n                if self.shift_byte_bits == 8:\n                  \
      \  #output_items[1].append(self.shift_byte)\n                    \n        \
      \            # first CC1101 whitening mask byte is always 0xFF\n           \
      \         self.pkt_len = self.shift_byte ^ 0xFF\n                    #print(f'packet\
      \ length byte {self.shift_byte:#04x}: {self.pkt_len} ({self.pkt_len * 8} bits)')\n\
      \                    \n                    # transition to state 2\n       \
      \             self.shift_byte = 0\n                    self.shift_byte_bits\
      \ = 0\n                    self.sync_state = 2\n                    continue\n\
      \ \n            # consume data bytes\n            if self.sync_state == 2:\n\
      \                self.shift_byte = ((self.shift_byte << 1) | (bit & 1)) & 0xFF\n\
      \                self.shift_byte_bits += 1\n                \n             \
      \   output_items[0][i] = 1\n                \n                #if self.shift_byte_bits\
      \ & 7 == 0:\n                    #print(self.shift_byte)\n                 \
      \   #output_items[1].append(self.shift_byte)\n                \n           \
      \     if self.shift_byte_bits == self.pkt_len * 8:\n                    # transition\
      \ to state 0\n                    self.shift_reg = 0\n                    self.sync_state\
      \ = 0\n                    continue\n \n        return len(output_items[0])\n\
      \n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sync_bits: '32'
    sync_word: '523575093'
  states:
    _io_cache: ('Sync Word Finder', 'blk', [('sync_word', '523575093'), ('sync_bits',
      '32')], [('0', 'byte', 1)], [('0', 'short', 1)], 'Embedded Python Block example
      - a simple multiply const', ['sync_bits', 'sync_word'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [712, 1772.0]
    rotation: 0
    state: true
- name: epy_block_1_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass powerg_sync_blk(gr.basic_block):  # other\
      \ base classes are basic_block, decim_block, interp_block\n    \"\"\"PowerG:\
      \ output packets on sync word\"\"\"\n\n    def __init__(self, sync_word=0x1F351F35,\
      \ sync_bits=32):\n        gr.basic_block.__init__(\n            self,\n    \
      \        name='PowerG Sync Output',   # will show up in GRC\n            in_sig=[np.ubyte],\n\
      \            out_sig=[np.ubyte]\n        )\n        \n        if sync_word ==\
      \ 0:\n            raise Exception('sync word of 0 not supported')\n        \n\
      \        # if an attribute with the same name as a parameter is found,\n   \
      \     # a callback is registered (properties work, too).\n        self.sync_word\
      \ = sync_word\n        self.sync_bits = sync_bits\n        \n        # register\
      \ for shifting in sync word\n        self.sync_mask = 2**self.sync_bits - 1\n\
      \        self.shift_reg = 0\n        \n        # shift in data bytes\n     \
      \   self.shift_byte = 0\n        self.shift_byte_bits = 0\n        \n      \
      \  self.pkt_len = 0\n        \n        self.sync_state = 0\n\n    def general_work(self,\
      \ input_items, output_items):\n        out_i = 0\n\n        for i, bit in enumerate(input_items[0]):\n\
      \            self.consume(0, 1)\n            \n            # find sync word\n\
      \            if self.sync_state == 0:\n                self.shift_reg = ((self.shift_reg\
      \ << 1) | (bit & 1)) & self.sync_mask\n                \n                if\
      \ self.shift_reg == self.sync_word:\n                    # transition to state\
      \ 1\n                    self.sync_state = 1\n                    self.shift_byte\
      \ = 0\n                    self.shift_byte_bits = 0\n                    continue\n\
      \                    \n            # shift in length byte\n            if self.sync_state\
      \ == 1:\n                self.shift_byte = ((self.shift_byte << 1) | (bit &\
      \ 1)) & 0xFF\n                self.shift_byte_bits += 1\n                \n\
      \                if self.shift_byte_bits == 8:\n                    output_items[0][out_i]\
      \ = self.shift_byte\n                    out_i += 1\n                    \n\
      \                    # first CC1101 whitening mask byte is always 0xFF\n   \
      \                 # add 2 for CRC-16 bytes\n                    self.pkt_len\
      \ = (self.shift_byte ^ 0xFF) + 2\n                    #print(f'packet length\
      \ byte {self.shift_byte:#04x}: {self.pkt_len} ({self.pkt_len * 8} bits)')\n\
      \                    \n                    # transition to state 2\n       \
      \             self.shift_byte = 0\n                    self.shift_byte_bits\
      \ = 0\n                    self.sync_state = 2\n                    continue\n\
      \ \n            # consume data bytes\n            if self.sync_state == 2:\n\
      \                self.shift_byte = ((self.shift_byte << 1) | (bit & 1)) & 0xFF\n\
      \                self.shift_byte_bits += 1\n                \n             \
      \   if self.shift_byte_bits & 7 == 0:\n                    #print(self.shift_byte)\n\
      \                    output_items[0][out_i] = self.shift_byte\n            \
      \        out_i += 1\n                \n                if self.shift_byte_bits\
      \ == self.pkt_len * 8:\n                    # transition to state 0\n      \
      \              self.shift_reg = 0\n                    self.sync_state = 0\n\
      \                    continue\n \n        #return len(output_items[0])\n   \
      \     return out_i\n\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sync_bits: '32'
    sync_word: '523575093'
  states:
    _io_cache: '(''PowerG Sync Output'', ''powerg_sync_blk'', [(''sync_word'', ''523575093''),
      (''sync_bits'', ''32'')], [(''0'', ''byte'', 1)], [(''0'', ''byte'', 1)], ''PowerG:
      output packets on sync word'', [''sync_bits'', ''sync_word''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [712, 1836.0]
    rotation: 0
    state: disabled
