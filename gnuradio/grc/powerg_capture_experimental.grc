  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 252.0]
    rotation: 0
    state: true
- name: chan_center_freq
  id: variable
  parameters:
    comment: ''
    value: bottom_freq + chan_id * chan_spacing
